generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id           String        @id
  name         String
  description  String        @default("")
  baseUrl      String
  environment  String        @default("production")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  environments Environment[]
  testTargets  TestTarget[]
  testSuites   TestSuite[]
  testRuns     TestRun[]
}

model TestTarget {
  id        String    @id
  projectId String
  name      String
  type      String
  url       String    @default("")
  localPath String    @default("")
  config    String    @default("{}")
  enabled   Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testRuns  TestRun[]
}

model Environment {
  id            String    @id
  projectId     String
  name          String
  baseUrl       String
  authType      String    @default("none")
  authConfig    String    @default("{}")
  customHeaders String    @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testRuns      TestRun[]
}

model TestSuite {
  id          String     @id
  projectId   String
  name        String
  type        String
  description String     @default("")
  config      String     @default("{}")
  enabled     Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCases   TestCase[]
  testRuns    TestRun[]
}

model TestCase {
  id             String    @id
  suiteId        String
  code           String
  name           String
  description    String    @default("")
  priority       String    @default("medium")
  enabled        Boolean   @default(true)
  expectedResult String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  suite          TestSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)

  @@unique([suiteId, code])
}

model TestRun {
  id                String       @id
  projectId         String?
  suiteId           String?
  environmentId     String?
  targetId          String?
  url               String
  status            String
  total             Int          @default(0)
  passed            Int          @default(0)
  failed            Int          @default(0)
  skipped           Int          @default(0)
  durationMs        Int          @default(0)
  generatedSpecPath String       @default("")
  rawOutputPath     String       @default("")
  userRequest       String       @default("")
  stdout            String       @default("")
  stderr            String       @default("")
  generatedCode     String       @default("")
  createdAt         DateTime     @default(now())
  project           Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  suite             TestSuite?   @relation(fields: [suiteId], references: [id], onDelete: SetNull)
  environment       Environment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)
  target            TestTarget?  @relation(fields: [targetId], references: [id], onDelete: SetNull)
  results           TestResult[]
  artifacts         Artifact[]
}

model TestResult {
  id             String     @id
  runId          String
  caseCode       String
  caseName       String
  status         String
  durationMs     Int        @default(0)
  errorMessage   String     @default("")
  stackTrace     String     @default("")
  expectedResult String     @default("")
  aiDiagnosis    String     @default("")
  run            TestRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  artifacts      Artifact[]
}

model Artifact {
  id        String      @id
  runId     String
  resultId  String?
  type      String
  path      String
  createdAt DateTime    @default(now())
  run       TestRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  result    TestResult? @relation(fields: [resultId], references: [id], onDelete: SetNull)
}

model AIRequestLog {
  id         String   @id
  provider   String
  model      String
  prompt     String
  response   String
  status     String
  durationMs Int      @default(0)
  createdAt  DateTime @default(now())
}
